+ni = 1.45E10
+un = 1350	up = 450
+A = 0.0870	Agd = 0.0700	wb = 95.5E-4	
+Nb = 1.45E14	taub = 30E-6	
+Ise = 4.7E-12	Cje = 57.4p
+Cjs = 57.4p
+Vth = 4.5	Kp = 2.137
+Cox = 4.75n	Cgs = 650p
+Rs = 18.1m	Rg = 9.0
+Lc = 3E-4
