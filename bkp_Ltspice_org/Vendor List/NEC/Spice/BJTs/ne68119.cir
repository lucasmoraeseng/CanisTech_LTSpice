*       CCB   = 0.07pF           LB  = 1.13nH             
*       CCE   = 0.01pF           LE  = 0.85nH           
*       CCBpkg= 0.18pF           Lbx = 0.19nH          
*       CCEpkg= 0.21pF           Lcx = 0.19nH             
*                                Lex = 0.19nH          
*
*                   c b e
.SUBCKT NE68119/CEL 2 1 3
Q1  5 7 8 NE68100
CCB 7 5 0.07E-12
CCE 5 8 0.01E-12
LE  8 6 0.85E-9
LB  4 7 1.13E-9
