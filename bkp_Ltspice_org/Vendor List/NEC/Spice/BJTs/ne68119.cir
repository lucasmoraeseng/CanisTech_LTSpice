+ MJE=0.5        CJC=0.8e-12      VJC=0.27       MJC=0.560        XCJC=0  
+ CJS=0          VJS=0.75         MJS=0          FC=0.50          TF=14e-12
+ XTF=3          VTF=25           ITF=0.1        PTF=0            TR=0.3e-9
+ EG=1.11        XTB=0            XTI=3          KF=0             AF=1   )
