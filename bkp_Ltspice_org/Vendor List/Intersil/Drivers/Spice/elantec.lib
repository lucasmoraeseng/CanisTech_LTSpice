visb  3010 4310 0V
h2b   4310 4410 v1b 1.0
r1b   14 4510  100
l1b   4510 4410 25nH
i1b   11   0 1uA   
i2b   14   0 5uA
R12b	11 0 2Meg
* Slew Rate Limiting
h1b   4610  0 visb 1400
r2b   4610 3110 1k
d1b   3110  0   dclamp
d2b    0  3110  dclamp
* High Frequency Pole 
