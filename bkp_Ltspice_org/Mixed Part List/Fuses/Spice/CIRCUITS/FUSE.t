+ {1.76M*IB^(2+RCOLDE)*KS}, {-1.48U*IB^(2+RCOLDE)*KS}, {484P*IB^(2+RCOLDE)*KS} 
C1 59 0 {.5M*IB^(HCTE)*TB}
G3 11 12 11 12 0, {389*IB^(2+RCOLDE)*KS)}, {-884M*IB^(2+RCOLDE)*KS},
+ {1.76M*IB^(2+RCOLDE)*KS}, {-1.48U*IB^(2+RCOLDE)*KS}, {484P*IB^(2+RCOLDE)*KS} 
C2 12 0 {.5M*IB^(HCTE)*TB}
V3 11 0 300
